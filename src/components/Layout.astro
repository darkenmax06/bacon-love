---
import "./layout.css"
import Menu from "./Menu.astro"
import Footer from "./Footer.astro"
import esCtas from "../translations/es"
import enCtas from "../translations/en"

// Definimos las propiedades que recibe el Layout
const {
  title = "Bacon Love - Amor al bacon",
  home, about, testimonials, menu, appointments, orderLink, languajes, rights, address,
  brand, contact, hours, quickLinks, // Receives footer quickLinks
  description = "Somos un restaurante emergente que fusiona la alta cocina con platos cotidianos. Descubre una experiencia gastronómica artesanal única.",
  lang = "es", // Recibimos el idioma por prop o lo detectamos
  links, // Receives the navigation links object
  alternateLinks, // { es: "/es/...", en: "/en/..." }
  robots = "index,follow",
  canonical, // Optional canonical override
  jsonLd // Optional JSON-LD structured data string
} = Astro.props

// Generamos la URL canonical dinámica
const baseUrl = "https://baconlove.es"
const canonicalURL = canonical || new URL(Astro.url.pathname, baseUrl );

const path = Astro.url.pathname.replace(/^\/(es|en)/, '') || '/';

    const getAlternatePath = (targetLang) => {
      if (alternateLinks?.[targetLang]) return `https://baconlove.es${alternateLinks[targetLang]}`;
      
      let targetPath = path;
      // Handle page-specific slug translation in fallback
      if (path.includes('citas') && targetLang === 'en') targetPath = path.replace('citas', 'appointments');
      if (path.includes('appointments') && targetLang === 'es') targetPath = path.replace('appointments', 'citas');
      if (path.includes('carta') && targetLang === 'en') targetPath = path.replace('carta', 'menu');
      if (path.includes('menu') && targetLang === 'es') targetPath = path.replace('menu', 'carta');
      if (path.includes('nosotros') && targetLang === 'en') targetPath = path.replace('nosotros', 'about');
      if (path.includes('about') && targetLang === 'es') targetPath = path.replace('about', 'nosotros');
      if (path.includes('contacto') && targetLang === 'en') targetPath = path.replace('contacto', 'contact');
      if (path.includes('contact') && targetLang === 'es') targetPath = path.replace('contact', 'contacto');

      return `https://baconlove.es/${targetLang}${targetPath}`;
    }

    const ctas = lang === 'en' ? enCtas.ctas : esCtas.ctas;
---

<html lang={lang}>
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NVFXR6KT');</script>
    <!-- End Google Tag Manager -->
    <meta charset="utf-8" />
    <meta name="google-site-verification" content="WvUW7Ealv0_Rn8c9YND0br__baaWpClH9qji_lSo5lo" />
    <link rel="icon" type="image/svg+xml" href="/a.png" />
    <meta name="viewport" content="width=device-width" />
    
    <title>{title}</title>
    <meta name="description" content={description} >
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content={robots} >

    <link rel="alternate" hreflang="es" href={getAlternatePath('es')} />
    <link rel="alternate" hreflang="en" href={getAlternatePath('en')} />
    <link rel="alternate" hreflang="x-default" href={getAlternatePath('es')} />

    <meta property="og:type" content="restaurant">
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content="https://baconlove.es/og.png">
    <meta property="og:locale" content={lang === 'en' ? 'en_GB' : 'es_ES'}>
    <meta property="og:locale:alternate" content={lang === 'en' ? 'es_ES' : 'en_GB'}>

    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content={canonicalURL}>
    <meta property="twitter:title" content={title}>
    <meta property="twitter:description" content={description}>
    <meta property="twitter:image" content="https://baconlove.es/og.png">

    <slot name="head" />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NVFXR6KT"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <a href="https://www.google.com/maps/dir/?api=1&destination=Calle+de+Sofia+177i+28022+Madrid" target="_blank" rel="noopener noreferrer" class="sticky-directions">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
      <span>{ctas.directions}</span>
    </a>

    <a href="tel:+34677063060" class="floating-call" aria-label={ctas.callNow}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      <span>{ctas.callNow}</span>
    </a>

    <a href="https://wa.me/34677063060" target="_blank" rel="noopener noreferrer" class="floating-whatsapp" aria-label="WhatsApp">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
    </a>

    <Menu languajes={languajes} home={home} about={about} testimonials={testimonials} menu={menu} appointments={appointments} orderLink={orderLink} links={links} lang={lang} alternateLinks={alternateLinks} />
    <main>
      <slot/>
    </main>
    <Footer rights={rights} address={address} brand={brand} contact={contact} hours={hours} quickLinks={quickLinks} />
  </body>
</html>