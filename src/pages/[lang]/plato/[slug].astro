---
import { getCollection, render } from 'astro:content';
import Layout from '../../../components/Layout.astro';
import "./plato.css"

import es from "../../../translations/es"
import en from "../../../translations/en"

const { lang, slug } = Astro.params;
const currentLang = lang as string;

const platos = await getCollection("platos");
const plato = platos.find(p => p.slug === slug);

if (!plato) {
  return Astro.redirect('/404');
}

const {data: {lang: platoLang, img, title, price, type}} = plato;

const splittedName = plato.slug.split("-");
splittedName.pop();
const baseName = splittedName.join("-");

if (currentLang !== platoLang) {
  return Astro.redirect(`/${currentLang}/plato/${baseName}-${currentLang}/`, 301);
}

const alternateLinks = {
  es: `/es/plato/${baseName}-es/`,
  en: `/en/plato/${baseName}-en/`
}

const {Content} = await render(plato)

const translations = {en, es}
const content = translations[platoLang as keyof typeof translations]

const languajes = Object.keys(translations)

const baseUrl = "https://baconlove.es";
const pageUrl = `${baseUrl}/${platoLang}/plato/${slug}/`;
const imageUrl = `${baseUrl}/content/${img}`;

const menuSectionLabel = platoLang === "es" ? "Carta" : "Menu";
const menuPageUrl = platoLang === "es" ? `${baseUrl}/es/carta/` : `${baseUrl}/en/menu/`;
const restaurantName = "Bacon Love";
const restaurantUrl = platoLang === "es" ? `${baseUrl}/es/` : `${baseUrl}/en/`;

const seoDescription = platoLang === "es"
  ? `${title} - ${type} artesanal en Bacon Love, hamburguesería en San Blas-Canillejas, Madrid. Precio: ${price}€.`
  : `${title} - Artisan ${type} at Bacon Love, burger restaurant in San Blas-Canillejas, Madrid. Price: €${price}.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MenuItem",
      "@id": pageUrl,
      "name": title,
      "url": pageUrl,
      "image": imageUrl,
      "offers": {
        "@type": "Offer",
        "price": price,
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock"
      },
      "suitableForDiet": "https://schema.org/GlutenFreeDiet",
      "menuAddOn": [],
      "inMenu": {
        "@type": "Menu",
        "name": menuSectionLabel,
        "url": menuPageUrl
      },
      "hasMenuSection": {
        "@type": "MenuSection",
        "name": type
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": restaurantName,
          "item": restaurantUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": menuSectionLabel,
          "item": menuPageUrl
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": title,
          "item": pageUrl
        }
      ]
    }
  ]
};
const jsonLdString = JSON.stringify(jsonLd);
---

<Layout
  languajes={languajes}
  {...content.footer}
  title={`${title} | Bacon Love`}
  description={seoDescription}
  lang={platoLang}
  {...content.menu}
  alternateLinks={alternateLinks}
  robots="index, follow"
  jsonLd={jsonLdString}
>
  <section class="plato">
    <div class="plato__price">
     EUR {plato.data.price} €
    </div>
    <div class="container">
      <picure class="plato__imgbox">
        <img src={`/content/${img}`} alt={`${title} - Bacon Love Hamburguesería San Blas-Canillejas, Madrid`}>
      </picure>
      <div class="plato__textbox">
        <Content/>
      </div>
    </div>
  </section>
</Layout>
